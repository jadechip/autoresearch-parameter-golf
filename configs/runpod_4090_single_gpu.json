  "optim": {
    "embed_lr": 0.003,
    "head_lr": 0.003,
    "matrix_lr": 0.012,
    "scalar_lr": 0.003,
    "beta1": 0.9,
    "beta2": 0.95,
    "adam_eps": 1e-08,
    "weight_decay": 0.0,
    "muon_momentum": 0.95,
    "muon_backend_steps": 5,
    "grad_clip_norm": 1.0,
    "warmup_steps": 20,
    "warmdown_steps": 100,
    "min_lr_scale": 0.1
  },
  "quant": {
    "keep_float_max_numel": 65536,
    "keep_float_name_patterns": [
      "norm",
      "scale",
      "gain",
      "adapter",
      "lm_head"
    ],
    "scale_store_dtype": "torch.float16",
    "keep_float_store_dtype": "torch.float16",
    "clip_percentile": 99.999,
    "zlib_level": 9
  }
