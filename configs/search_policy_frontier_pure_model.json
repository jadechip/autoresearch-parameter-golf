{
  "lane": "frontier_pure_model",
  "description": "Evidence-guided discovery and refinement policy for pure-model frontier search on a 5090. Use a stable near-frontier seed, isolate one primary novelty at a time, and only spend full runs on branches that clear projected throughput and byte gates.",
  "config_json": "./configs/autoresearch_5090_frontier_5min.json",
  "min_meaningful_bpb_gain": 0.001,
  "artifact_target_bytes_min": 15000000,
  "artifact_target_bytes_max": 15950000,
  "max_consecutive_losing_micro_experiments": 2,
  "max_consecutive_same_family_runs": 2,
  "story_selection_mode": "one_story_per_iteration",
  "allow_train_py_module_writes": true,
  "discovery_mode": "evidence_guided_feeder",
  "experiment_style": {
    "anchor_config_required": true,
    "primary_novelty_axes": 1,
    "max_macro_axis_changes": 2,
    "prefer_budget_repair_before_new_family": true
  },
  "refinement_gate": {
    "contender_bpb_gap": 0.015,
    "require_ranking_valid": true,
    "prefer_post_quant_refine": true
  },
  "preflight": {
    "enabled": true,
    "benchmark_train_steps": 2,
    "min_train_tokens_per_second_ratio": 0.9,
    "min_total_tokens_ratio": null,
    "require_train_tokens_per_second_ratio": true,
    "require_projected_total_tokens_ratio": false,
    "hard_artifact_bytes_max": 16000000,
    "soft_artifact_bytes_max": 15950000,
    "soft_artifact_bytes_min": 14500000,
    "allow_slow_if_within_soft_cap": true,
    "allow_slow_if_artifact_gain_bytes": 750000,
    "use_projected_artifact_gate": true,
    "strict_projected_artifact_hard_cap": true,
    "projected_artifact_margin_bytes": 250000,
    "no_lawa": true,
    "no_eval_first_step": true,
    "disable_reload_verify": true,
    "train_phase_only": true,
    "preflight_exit_code": 10
  },
  "creative_guardrails": {
    "treat_public_frontier_as_prior_not_recipe": true,
    "require_new_mechanism_or_two_macro_axis_changes_for_structural_runs": true,
    "avoid_exact_public_architecture_cloning": true,
    "prefer_clean_isolated_stories": true,
    "one_primary_novelty_per_run": true,
    "prefer_stable_frontier_seed_over_wholesale_rebuild": true
  },
  "frontier_reference_features": [
    "near-cap 11-12 layer 512-dim carriers",
    "strong post-quant selection and checkpoint choice",
    "mixed low-bit or coarse selective quantization",
    "1024-1536 context only when throughput is protected",
    "activation, rope, and residual-scale variants that stay local to train.py"
  ],
  "do_not_overweight": [
    "Do not merely transpose a public winning config into this repo.",
    "Keep at least one material difference in carrier, schedule, module placement, or quant grouping.",
    "Do not test topology plus quantization plus curriculum plus module-family changes in one 5-minute proxy.",
    "Treat INT4-only MLP branches and heavyweight local modules as later, lower-priority ideas unless a stable anchor already exists."
  ],
  "train_config_preferences": {
    "config_transform_profile": "manual",
    "preferred_local_knobs": [
      "rope_fraction",
      "mlp_activation",
      "residual_scale_init",
      "quant.named_low_bit_rules",
      "quant.clip_percentile_overrides"
    ]
  }
}
