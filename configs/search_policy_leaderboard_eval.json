{
  "lane": "leaderboard_eval",
  "description": "Policy for competition-score search where evaluation-side legality matters. Pure-model quality still matters, but eval-aware branches are allowed once a strong carrier exists.",
  "min_meaningful_bpb_gain": 0.001,
  "artifact_target_bytes_min": 15000000,
  "artifact_target_bytes_max": 15950000,
  "max_consecutive_losing_micro_experiments": 2,
  "max_consecutive_same_family_runs": 2,
  "story_selection_mode": "one_story_per_iteration",
  "allow_train_py_module_writes": true,
  "discovery_mode": "feeder_then_refine",
  "refinement_gate": {
    "contender_bpb_gap": 0.018,
    "require_ranking_valid": true,
    "prefer_post_quant_refine": true
  },
  "preflight": {
    "enabled": true,
    "benchmark_train_steps": 2,
    "min_train_tokens_per_second_ratio": 0.85,
    "min_total_tokens_ratio": 0.75,
    "hard_artifact_bytes_max": 16000000,
    "soft_artifact_bytes_max": 15950000,
    "soft_artifact_bytes_min": 13800000,
    "allow_slow_if_within_soft_cap": true,
    "allow_slow_if_artifact_gain_bytes": 1000000,
    "no_lawa": true,
    "no_eval_first_step": true,
    "disable_reload_verify": true,
    "preflight_exit_code": 10
  },
  "creative_guardrails": {
    "treat_public_frontier_as_prior_not_recipe": true,
    "require_new_mechanism_or_two_macro_axis_changes_for_structural_runs": true,
    "avoid_exact_public_architecture_cloning": true,
    "prefer_clean_isolated_stories": true,
    "allow_eval_lane_only_after_strong_carrier": true
  },
  "frontier_reference_features": [
    "separate pure-model and eval-aware branches",
    "cache or TTT only when legality and eval budget remain clear",
    "strong carrier first, eval-time story second"
  ],
  "do_not_overweight": [
    "Do not start from eval tricks on a weak carrier.",
    "Do not blend XSA, cache, TTT, and Canon in one first attempt.",
    "Keep pure-model and eval-aware branches separate until one is clearly real."
  ],
  "train_config_preferences": {
    "config_transform_profile": "manual",
    "preferred_local_knobs": [
      "rope_fraction",
      "mlp_activation",
      "residual_scale_init",
      "quant.named_low_bit_rules",
      "quant.clip_percentile_overrides"
    ]
  }
}
