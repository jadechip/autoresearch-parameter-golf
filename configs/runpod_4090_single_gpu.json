{
  "train_pattern": "/workspace/data/fineweb_train_*.bin",
  "val_pattern": "/workspace/data/fineweb_val_*.bin",
  "tokenizer_path": "/workspace/data/fineweb_1024_bpe.model",
  "output_dir": "./runs/runpod_4090_single_gpu",
  "run_name": null,
  "results_tsv_path": "./results.tsv",
  "seed": 1337,
  "deterministic": true,
  "iterations": 200000,
  "train_batch_tokens": 65536,
  "val_batch_tokens": 65536,
  "grad_accum_steps": 4,
  "log_every": 20,
  "val_every": 100,
  "max_wallclock_seconds": 1800.0,
  "checkpoint_every": 100,
  "resume_from": null,
  "use_compile": false,
  "use_lawa": true,
  "lawa_last_n_steps": 100,
  "save_final_quantized": true,
  "verify_export_reload": true,
  "evaluate_only": false,
  "load_artifact_path": null,
  "benchmark_only": false,
  "benchmark_train_steps": 3,
  "benchmark_eval_repeats": 1,
  "counted_code_paths": [
    "train.py"
  ],
  "artifact_bundle_name": "submission_bundle",
  "model": {
    "vocab_size": 1024,
    "seq_len": 512,
    "d_model": 512,
    "num_heads": 8,
    "num_kv_heads": 4,
    "mlp_mult": 2,
    "rope_base": 10000.0,
    "logit_softcap": 30.0,
    "tie_embeddings": true,
    "emb_init_std": 0.02,
    "stem_layers": 1,
    "shared_layers": 2,
    "recurrence_loops": 4,
    "tail_layers": 1,
    "adapter_rank": 4,
    "adapter_alpha": 8.0,
    "adapter_targets": [
      "attn_out",
      "mlp_out"
    ],
    "qk_gain_init": 1.0,
    "fake_quant_during_train": true,
    "fake_quant_start_step": 50,
    "attn_dropout": 0.0,
    "resid_dropout": 0.0
